class Plotter:
    """Creates backtest visualizations"""
    
    def __init__(self, config: BacktestConfig):
        self.config = config
    
    def create_all_charts(self, trades_df: pd.DataFrame, portfolio_df: pd.DataFrame):
        """Generate all visualization charts"""
        output_dir = self.config.output_dir
        prefix = self.config.output_prefix
        
        if not os.path.exists(output_dir):
            os.makedirs(output_dir)
        
        print("Generating visualizations...")
        
        # 1. Portfolio value chart (with benchmark)
        self._plot_portfolio_value_with_benchmark(portfolio_df, trades_df, output_dir, prefix)
        
        # 2. Portfolio value chart (without benchmark)
        self._plot_portfolio_value(portfolio_df, output_dir, prefix)
        
        # 3. BTC allocation chart
        self._plot_btc_allocation(portfolio_df, output_dir, prefix)
        
        # 4. Drawdown chart
        self._plot_drawdown(portfolio_df, output_dir, prefix)
        
        # 5. Trade distribution charts
        if not trades_df.empty:
            self._plot_win_rate_by_exit(trades_df, output_dir, prefix)
            self._plot_position_size_distribution(trades_df, output_dir, prefix)
            self._plot_hold_time_distribution(trades_df, output_dir, prefix)
            self._plot_profit_loss_distribution(trades_df, output_dir, prefix)
            self._plot_position_size_vs_feature(trades_df, output_dir, prefix)
            self._plot_entry_distribution(trades_df, output_dir, prefix)
        
        # 6. Cash utilization chart
        self._plot_cash_utilization(portfolio_df, output_dir, prefix)
        
        # 7. Combined performance chart (Strategy + BTC + Combined)
        self._plot_combined_performance_chart(portfolio_df, output_dir, prefix)
        
        print(f"Visualizations saved to {output_dir}")
    
