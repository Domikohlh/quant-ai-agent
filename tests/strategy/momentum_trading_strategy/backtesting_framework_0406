                f.write(f"- {metric.replace('_', ' ').title()}: {p_value:.4f} {significance}\n")
            
            f.write("\n* p < 0.1, ** p < 0.05, *** p < 0.01\n")
            f.write("Lower p-values indicate better performance than random chance\n\n")
            
