class MonteCarloTester:
    """Performs Monte Carlo permutation testing on backtest results"""
    
    def __init__(self, config: BacktestConfig):
        self.config = config

    @staticmethod
    def run_single_iteration(args):
        """Run a single Monte Carlo iteration (for parallel processing)"""
        i, data, config, mc_tester = args
        
        try:
            # Create permuted data
            seed = config.monte_carlo_seed + i
            permuted_data = mc_tester.create_permuted_price_series(data, seed)
            
            # Create a copy of config for this permutation
            perm_config = BacktestConfig()
            # Copy all attributes from original config
            for attr, value in vars(config).items():
                setattr(perm_config, attr, value)
            
            # Run backtest on permuted data with potentially updated config
            perm_engine = BacktestEngine(perm_config, permuted_data, 
                                       config.feature_column, config.price_column)
            perm_trades, perm_portfolio = perm_engine.run()
            
            # Calculate metrics
            perm_analyzer = PerformanceAnalyzer(perm_config)
            perm_metrics = perm_analyzer.calculate_metrics(perm_trades, perm_portfolio)
            
            # Add permutation info
            perm_metrics['permutation_id'] = i
            perm_metrics['sigmoid_midpoint'] = perm_config.sigmoid_midpoint
            perm_metrics['sigmoid_steepness'] = perm_config.sigmoid_steepness
            
            return perm_metrics
            
        except Exception as e:
            print(f"Warning: Error in permutation {i}: {e}")
            return None

    def create_permuted_price_series(self, price_data: pd.DataFrame, seed: int) -> pd.DataFrame:
        """Create permuted price series using block bootstrap"""
        rng = np.random.RandomState(seed)
        

        # Get price series
        price_col = self.config.price_column
        prices = price_data[price_col].values
        start_price = prices[0]
        end_price = prices[-1]
        original_max = prices.max()
        original_min = prices.min()
        # Calculate returns
        returns = price_data[price_col].pct_change().dropna().values
        n_returns = len(returns)
        returns_array = returns

        if n_returns > 50000:
            block_size = max(50, n_returns // 1000)  # Larger blocks for stability
        elif n_returns > 10000:
            block_size = max(100, n_returns // 500)   
        else:
            block_size = max(200, n_returns // 50)    

        # Create blocks
        block_size = min(block_size, n_returns // 10, 1000)
        blocks = []
        
        for i in range(0, n_returns - block_size + 1, block_size):
            end_idx = min(i + block_size, n_returns)
            block = returns_array[i:end_idx].copy()
            blocks.append(block)   

        remainder = n_returns % block_size
        if remainder > 0:
            remaining_block = returns_array[-remainder:].copy()
            blocks.append(remaining_block)
         
        # Shuffle blocks
        block_indices = list(range(len(blocks)))
        rng.shuffle(block_indices)
        shuffled_blocks = [blocks[i] for i in block_indices]
        shuffled_returns = np.concatenate(shuffled_blocks)
        

        if len(shuffled_returns) > n_returns:
            shuffled_returns = shuffled_returns[:n_returns]
        elif len(shuffled_returns) < n_returns:
            # Pad with random selection from existing returns
            needed = n_returns - len(shuffled_returns)
            padding_indices = rng.choice(len(returns_array), size=needed, replace=True)
            padding = returns_array[padding_indices]
            shuffled_returns = np.concatenate([shuffled_returns, padding])  

        max_attempts = 5
        strategies = ['block', 'constrained', 'capped', 'filtered', 'fallback']
        
        for attempt, strategy in enumerate(strategies):
            
            if strategy == 'block' and attempt == 0:
                # Use the block bootstrap result
                final_returns = shuffled_returns
            elif strategy == 'constrained':
                # Apply return constraints before shuffling
                return_std = returns_array.std()
                return_mean = returns_array.mean()
                # Clip extreme returns to 3 standard deviations
                clipped_returns = np.clip(returns_array, 
                                        return_mean - 3*return_std, 
                                        return_mean + 3*return_std)
                shuffled_indices = rng.permutation(len(clipped_returns))
                final_returns = clipped_returns[shuffled_indices]
            elif strategy == 'capped':
                # Use percentile-based capping
                p1, p99 = np.percentile(returns_array, [1, 99])
                capped_returns = np.clip(returns_array, p1, p99)
                shuffled_indices = rng.permutation(len(capped_returns))
                final_returns = capped_returns[shuffled_indices]
            elif strategy == 'filtered':
                # Remove extreme outliers then shuffle
                q1, q3 = np.percentile(returns_array, [25, 75])
                iqr = q3 - q1
                lower_bound = q1 - 3 * iqr
                upper_bound = q3 + 3 * iqr
                mask = (returns_array >= lower_bound) & (returns_array <= upper_bound)
                if mask.sum() > n_returns // 2:  # Ensure we have enough data
                    filtered_returns = returns_array[mask]
                    # Sample with replacement to get original length
                    final_returns = rng.choice(filtered_returns, size=n_returns, replace=True)
                else:
                    final_returns = shuffled_returns  # Fall back to original shuffle
            else:  # fallback
                # Simple random permutation
                shuffled_indices = rng.permutation(len(returns_array))
                final_returns = returns_array[shuffled_indices]
            
            # Reconstruct prices
            reconstructed_prices = [start_price]
            current_price = start_price
            max_price_seen = start_price
            min_price_seen = start_price
            extreme_detected = False
            for ret in final_returns:
                current_price = current_price * (1 + ret)
                reconstructed_prices.append(current_price)
                
                max_price_seen = max(max_price_seen, current_price)
                min_price_seen = min(min_price_seen, current_price)
                
                # More conservative extreme detection
                if (max_price_seen > original_max * 5 or 
                    min_price_seen < max(original_min * 0.2, start_price * 0.01) or
                    current_price <= 0):
                    extreme_detected = True
                    break
            
            if not extreme_detected:
                break
        else:
            # Ultimate fallback: use original prices with small random noise
            noise_level = 0.01  # 1% noise
            noise = rng.normal(0, noise_level, len(prices))
            reconstructed_prices = prices * (1 + noise)
            reconstructed_prices[0] = start_price  # Ensure start price
            reconstructed_prices[-1] = end_price   # Ensure end price
            
            # Create permuted dataframe
            permuted_data = price_data.copy()
            permuted_data[price_col] = reconstructed_prices
            return permuted_data
            
        reconstructed_end_price = reconstructed_prices[-1]
        if reconstructed_end_price > 0:
            # Use multiplicative scaling that respects compounding returns
            # 1) Compute original vs. reconstructed gross returns
            P0 = start_price
            R_orig = end_price / P0
            R_recon = reconstructed_end_price / P0
            
            # 2) Derive per-step adjustment factor f
            N = len(final_returns)
            if R_recon > 0 and N > 0:
                f = (R_orig / R_recon) ** (1.0 / N)
                
                # 3) Scale each return multiplicatively
                scaled_returns = [(1 + r) * f - 1 for r in final_returns]
                
                # 4) Rebuild the price path using scaled returns
                scaled_prices = [P0]
                for r in scaled_returns:
                    new_price = scaled_prices[-1] * (1 + r)
                    # Prevent non-positive prices
                    scaled_prices.append(max(new_price, P0 * 0.001))
            else:
                # Fallback if calculation fails
                scaled_prices = prices.copy()
        else:
            # Fallback to the original series if reconstruction failed
            scaled_prices = prices.copy()
        
        # Create permuted dataframe
        permuted_data = price_data.copy()
        permuted_data[price_col] = scaled_prices
        
        return permuted_data
    
    def run_monte_carlo_test(self, data: pd.DataFrame, n_iterations: int = 100) -> Dict:
        """Run Monte Carlo permutation test"""
        print(f"Running Monte Carlo test with {n_iterations} iterations...")
        
        # Run original backtest
        engine = BacktestEngine(self.config, data, self.config.feature_column, self.config.price_column)
        original_trades, original_portfolio = engine.run()
        
        analyzer = PerformanceAnalyzer(self.config)
        original_metrics = analyzer.calculate_metrics(original_trades, original_portfolio)
        
        # Add sigmoid parameters to original metrics
        original_metrics['sigmoid_midpoint'] = self.config.sigmoid_midpoint
        original_metrics['sigmoid_steepness'] = self.config.sigmoid_steepness
        
        # Store permutation results
        mc_results = []
        
        # Decide whether to use parallel processing
        if self.config.parallel_mode and n_iterations > 1:
            print(f"Using parallel processing with {self.config.num_processes or mp.cpu_count()} processes...")
            
            # Prepare arguments for parallel processing
            args_list = [(i, data, self.config, self) for i in range(n_iterations)]
            
            # Create pool and run iterations in parallel
            with mp.Pool(processes=self.config.num_processes) as pool:
                # Use imap to get progress updates
                results_iter = pool.imap(MonteCarloTester.run_single_iteration, args_list)
                
                # Collect results with progress updates
                for i, result in enumerate(results_iter):
                    if result is not None:
                        mc_results.append(result)
                    if (i + 1) % 10 == 0:
                        print(f"Completed {i + 1}/{n_iterations} permutations...")
        else:
            # Sequential processing (original code)
            print("Using sequential processing...")
            
            for i in range(n_iterations):
                if (i + 1) % 10 == 0:
                    print(f"Completed {i + 1}/{n_iterations} permutations...")
                
                try:
                    # Create permuted data
                    seed = self.config.monte_carlo_seed + i
                    permuted_data = self.create_permuted_price_series(data, seed)
                    
                    # Create a copy of config for this permutation
                    perm_config = BacktestConfig()
                    # Copy all attributes from original config
                    for attr, value in vars(self.config).items():
                        setattr(perm_config, attr, value)
                    
                    # Run backtest on permuted data with potentially updated config
                    perm_engine = BacktestEngine(perm_config, permuted_data, 
                                               self.config.feature_column, self.config.price_column)
                    perm_trades, perm_portfolio = perm_engine.run()
                    
                    # Calculate metrics
                    perm_analyzer = PerformanceAnalyzer(perm_config)
                    perm_metrics = perm_analyzer.calculate_metrics(perm_trades, perm_portfolio)
                    
                    # Add permutation info
                    perm_metrics['permutation_id'] = i
                    perm_metrics['sigmoid_midpoint'] = perm_config.sigmoid_midpoint
                    perm_metrics['sigmoid_steepness'] = perm_config.sigmoid_steepness
                    
                    mc_results.append(perm_metrics)
                    
                except Exception as e:
                    print(f"Warning: Error in permutation {i}: {e}")
                    continue
        
        print(f"Completed {len(mc_results)} successful permutations")
        
        # Analyze results
        analysis = self._analyze_results(original_metrics, mc_results)
        
        return {
            'original': original_metrics,
            'permutations': mc_results,
            'analysis': analysis
        }
    
    def _analyze_results(self, original: Dict, permutations: List[Dict]) -> Dict:
        """Analyze Monte Carlo results"""
        if not permutations:
            return {}
        
        # Calculate p-values
        p_values = {}
        metrics = ['sharpe_ratio', 'total_return', 'profit_factor', 'win_rate']
        
        for metric in metrics:
            if metric in original:
                better_count = sum(1 for p in permutations if p.get(metric, 0) >= original[metric])
                p_values[metric] = better_count / len(permutations)
        
        # For max_drawdown, lower is better
        if 'max_drawdown' in original:
            better_count = sum(1 for p in permutations if p.get('max_drawdown', 1) <= original['max_drawdown'])
            p_values['max_drawdown'] = better_count / len(permutations)
        
        return {
            'p_values': p_values,
            'significant_metrics': [k for k, v in p_values.items() if v < 0.05]
        }
    
