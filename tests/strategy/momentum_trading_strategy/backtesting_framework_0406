class GridSearchOptimizer:
    """Performs grid search optimization on backtest parameters"""
    
    def __init__(self, config: BacktestConfig):
        self.config = config
        self.results = []
    
    def generate_parameter_combinations(self) -> List[Dict]:
        """Generate all parameter combinations from grid search config"""
        if not self.config.grid_search_params:
            return [{}]
        
        # Get parameter names and their possible values
        param_names = list(self.config.grid_search_params.keys())
        param_values = list(self.config.grid_search_params.values())
        
        # Generate all combinations
        combinations = []
        for combo in itertools.product(*param_values):
            param_dict = dict(zip(param_names, combo))
            combinations.append(param_dict)
        
        print(f"Generated {len(combinations)} parameter combinations")
        return combinations
    
    def run_single_backtest(self, params: Dict, merged_data: pd.DataFrame, 
                          feature_column: str, price_column: str) -> Dict:
        """Run a single backtest with given parameters"""
        # Create a copy of the config for this run
        test_config = BacktestConfig()
        
        # Copy all attributes from original config
        for attr, value in vars(self.config).items():
            setattr(test_config, attr, value)
        
        # Apply grid search parameters
        for param, value in params.items():
            if hasattr(test_config, param):
                setattr(test_config, param, value)
        
        # Set required columns
        test_config.feature_column = feature_column
        test_config.price_column = price_column
        
        # Calibrate position sizing
        position_manager = PositionManager(test_config)
        position_manager.calibrate_sigmoid(merged_data[feature_column].values)
        
        # Run backtest
        engine = BacktestEngine(test_config, merged_data, feature_column, price_column)
        trades_df, portfolio_df = engine.run()
        
        # Calculate performance
        analyzer = PerformanceAnalyzer(test_config)
        metrics = analyzer.calculate_metrics(trades_df, portfolio_df)
        
        # Add parameter information to metrics
        metrics['parameters'] = params.copy()
        
        return metrics
    
    def run_grid_search(self, merged_data: pd.DataFrame, feature_column: str, price_column: str) -> Dict:
        """Run grid search optimization"""
        print("\n" + "="*60)
        print("Running Grid Search Optimization")
        print("="*60)
        
        # Generate parameter combinations
        param_combinations = self.generate_parameter_combinations()
        
        print(f"Grid search parameters:")
        for param, values in self.config.grid_search_params.items():
            print(f"  {param}: {values}")
        
        print(f"\nOptimization objectives: {', '.join(self.config.grid_search_objectives)}")
        
        # Run backtests for all combinations
        all_results = []
        for i, params in enumerate(param_combinations):
            print(f"\nRunning backtest {i+1}/{len(param_combinations)}: {params}")
            
            try:
                metrics = self.run_single_backtest(params, merged_data, feature_column, price_column)
                all_results.append(metrics)
                
                # Print quick summary
                sharpe = metrics.get('sharpe_ratio', 0)
                total_ret = metrics.get('total_return_pct', 0)
                profit_factor = metrics.get('profit_factor', 0)
                print(f"  Results: Sharpe={sharpe:.3f}, Return={total_ret:.2f}%, PF={profit_factor:.3f}")
                
            except Exception as e:
                print(f"  Error: {e}")
                continue
        
        print(f"\nCompleted {len(all_results)} successful backtests out of {len(param_combinations)}")
        
        # Find best results for each objective
        best_results = self._find_best_results(all_results)
        
        return {
            'all_results': all_results,
            'best_results': best_results,
            'param_combinations': param_combinations
        }
    
    def _find_best_results(self, all_results: List[Dict]) -> Dict:
        """Find best results for each optimization objective"""
        best_results = {}
        
        for objective in self.config.grid_search_objectives:
            if not all_results:
                continue
                
            # Find best result for this objective
            best_result = None
            best_value = float('-inf')
            
            # For max_drawdown, lower is better (but we'll handle this specially)
            if objective == 'max_drawdown':
                best_value = float('inf')
            
            for result in all_results:
                if objective in result:
                    value = result[objective]
                    
                    # Handle max_drawdown (lower is better)
                    if objective == 'max_drawdown':
                        if value < best_value:
                            best_value = value
                            best_result = result
                    else:
                        # Higher is better for most metrics
                        if value > best_value:
                            best_value = value
                            best_result = result
            
            if best_result:
                best_results[objective] = best_result
                print(f"Best {objective}: {best_value:.4f} with params {best_result['parameters']}")
        
        return best_results
    
    def save_grid_search_results(self, grid_results: Dict, merged_data: pd.DataFrame, 
                               feature_column: str, price_column: str):
        """Save detailed results for best parameter combinations"""
        base_output_dir = self.config.output_dir
        
        for objective, best_result in grid_results['best_results'].items():
            # Create objective-specific directory
            objective_dir = os.path.join(base_output_dir, f"best_{objective}")
            if not os.path.exists(objective_dir):
                os.makedirs(objective_dir)
            
            print(f"\nSaving detailed results for best {objective} to {objective_dir}")
            
            # Create config for this best result
            best_config = BacktestConfig()
            
            # Copy all attributes from original config
            for attr, value in vars(self.config).items():
                setattr(best_config, attr, value)
            
            # Apply best parameters
            for param, value in best_result['parameters'].items():
                if hasattr(best_config, param):
                    setattr(best_config, param, value)
            
            # Set output directory and columns
            best_config.output_dir = objective_dir
            best_config.output_prefix = f"best_{objective}"
            best_config.feature_column = feature_column
            best_config.price_column = price_column
            
            # Run full backtest with visualizations and analysis
            self._run_full_backtest_analysis(best_config, merged_data, best_result)
        
        # Save summary of all results
        self._save_grid_search_summary(grid_results, base_output_dir)
    
    def _run_full_backtest_analysis(self, config: BacktestConfig, merged_data: pd.DataFrame, 
                                  result_metrics: Dict):
        """Run full backtest with all analysis and visualizations"""
        # Calibrate position sizing
        position_manager = PositionManager(config)
        position_manager.calibrate_sigmoid(merged_data[config.feature_column].values)
        
        # Run backtest
        engine = BacktestEngine(config, merged_data, config.feature_column, config.price_column)
        trades_df, portfolio_df = engine.run()
        
        # Calculate performance
        analyzer = PerformanceAnalyzer(config)
        metrics = analyzer.calculate_metrics(trades_df, portfolio_df)
        summary = analyzer.generate_summary(metrics)
        
        # Save results
        output_dir = config.output_dir
        trades_df.to_csv(os.path.join(output_dir, f"{config.output_prefix}_trading_log.csv"), index=False)
        portfolio_df.to_csv(os.path.join(output_dir, f"{config.output_prefix}_portfolio_history.csv"), index=False)
        
        # Add parameter information to summary
        param_summary = "\n\nOptimized Parameters:\n" + "="*50 + "\n"
        for param, value in result_metrics['parameters'].items():
            param_summary += f"- {param}: {value}\n"
        
        with open(os.path.join(output_dir, f"{config.output_prefix}_performance_summary.txt"), 'w') as f:
            f.write(summary + param_summary)
        
        # Generate visualizations
        visualizer = Plotter(config)
        visualizer.create_all_charts(trades_df, portfolio_df)
        
        print(f"  Saved trading log, portfolio history, summary, and visualizations")
    
    def _save_grid_search_summary(self, grid_results: Dict, base_output_dir: str):
        """Save comprehensive summary of grid search results"""
        summary_file = os.path.join(base_output_dir, "grid_search_summary.txt")
        
        with open(summary_file, 'w') as f:
            f.write("Grid Search Optimization Summary\n")
            f.write("=" * 50 + "\n\n")
            
            f.write("Grid Search Configuration:\n")
            f.write("-" * 30 + "\n")
            for param, values in self.config.grid_search_params.items():
                f.write(f"- {param}: {values}\n")
            
            f.write(f"\nObjectives optimized: {', '.join(self.config.grid_search_objectives)}\n")
            f.write(f"Total combinations tested: {len(grid_results['param_combinations'])}\n")
            f.write(f"Successful backtests: {len(grid_results['all_results'])}\n\n")
            
            f.write("Best Results by Objective:\n")
            f.write("-" * 30 + "\n")
            for objective, best_result in grid_results['best_results'].items():
                f.write(f"\nBest {objective.upper()}: {best_result[objective]:.4f}\n")
                f.write("Parameters:\n")
                for param, value in best_result['parameters'].items():
                    f.write(f"  - {param}: {value}\n")
                
                # Add key performance metrics
                f.write("Key Metrics:\n")
                f.write(f"  - Sharpe Ratio: {best_result.get('sharpe_ratio', 0):.3f}\n")
                f.write(f"  - Total Return: {best_result.get('total_return_pct', 0):.2f}%\n")
                f.write(f"  - Profit Factor: {best_result.get('profit_factor', 0):.3f}\n")
                f.write(f"  - Max Drawdown: {best_result.get('max_drawdown_pct', 0):.2f}%\n")
                f.write(f"  - Win Rate: {best_result.get('win_rate', 0):.2f}%\n")
        
        # Save detailed results CSV
        results_df = pd.DataFrame(grid_results['all_results'])
        results_df.to_csv(os.path.join(base_output_dir, "grid_search_all_results.csv"), index=False)
        
        print(f"Grid search summary saved to {summary_file}")
        print(f"All results saved to {os.path.join(base_output_dir, 'grid_search_all_results.csv')}")


def main(config=None):
    """Main execution function"""
    pd.options.mode.chained_assignment = None  # Disable pandas warnings
    
    # Create configuration
    if config is None:
        config = BacktestConfig()
    
    # Load and merge data (only once)
    data_handler = DataHandler(config)
    merged_data = data_handler.load_and_merge()
    
    # Update config with detected columns
    config.feature_column = data_handler.feature_column
    config.price_column = data_handler.price_column
    
    # Check if grid search is enabled
    if config.grid_search_enabled and config.grid_search_params:
        print("Grid Search Mode Enabled")
        
        # Run grid search optimization
        grid_optimizer = GridSearchOptimizer(config)
        grid_results = grid_optimizer.run_grid_search(merged_data, config.feature_column, config.price_column)
        
        # Save detailed results for best combinations
        grid_optimizer.save_grid_search_results(grid_results, merged_data, config.feature_column, config.price_column)
        
        print(f"\nGrid search completed! Check {config.output_dir} for results.")
        return grid_results
    
    else:
        print("Single Backtest Mode")
        
        # Original single backtest execution
        # Calibrate position sizing
        position_manager = PositionManager(config)
        position_manager.calibrate_sigmoid(merged_data[config.feature_column].values)
        
        # Run backtest
        engine = BacktestEngine(config, merged_data, config.feature_column, config.price_column)
        trades_df, portfolio_df = engine.run()
        
