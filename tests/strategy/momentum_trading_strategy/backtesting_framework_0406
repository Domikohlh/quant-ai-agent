        mc_df.to_csv(os.path.join(output_dir, f"{config.output_prefix}_monte_carlo_results.csv"), index=False)
        
        # Print summary
        p_values = mc_results['analysis']['p_values']
        significant = mc_results['analysis']['significant_metrics']
        
        print("\nMonte Carlo Results:")
        print(f"P-values (vs random chance):")
        for metric, p_val in p_values.items():
            sig = "***" if p_val < 0.01 else "**" if p_val < 0.05 else "*" if p_val < 0.1 else ""
            print(f"  {metric}: {p_val:.3f} {sig}")
        
        if significant:
            print(f"\nStrategy shows significant performance in: {', '.join(significant)}")
        else:
            print("\nStrategy does not show statistically significant outperformance.")
        
        # Save detailed Monte Carlo analysis
        analysis_file = os.path.join(output_dir, f"{config.output_prefix}_monte_carlo_analysis.txt")
        with open(analysis_file, 'w') as f:
            f.write("Monte Carlo Permutation Test Analysis\n")
