        print("Running Monte Carlo Permutation Test")
        print("="*60)
        
        mc_tester = MonteCarloTester(config)
        mc_results = mc_tester.run_monte_carlo_test(merged_data, config.monte_carlo_iterations)
        
        # Plot results
        mc_tester.plot_results(mc_results, output_dir, config.output_prefix)
        
        # Save results
