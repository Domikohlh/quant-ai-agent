        portfolio_df.to_csv(os.path.join(output_dir, f"{config.output_prefix}_portfolio_history.csv"), index=False)
        
        with open(os.path.join(output_dir, f"{config.output_prefix}_performance_summary.txt"), 'w') as f:
            f.write(summary)
            
        # Generate visualizations
        visualizer = Plotter(config)
        visualizer.create_all_charts(trades_df, portfolio_df)
    
    # Run Monte Carlo test if enabled
    if config.monte_carlo_enabled:
