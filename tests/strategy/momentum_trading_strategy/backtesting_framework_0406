    def _plot_win_rate_by_exit(self, trades_df: pd.DataFrame, output_dir: str, prefix: str):
        """Plot win rate by exit reason"""
        sell_trades = trades_df[trades_df['trade_type'].isin(['SELL', 'NET_SELL', 'EXACT_BALANCE', 'COVER', 'NET_COVER'])].dropna(subset=['profit_loss_pct', 'exit_reason'])
        
        if sell_trades.empty:
            return
        
        # Calculate win rates for each exit reason
        exit_stats = {}
        for reason in sell_trades['exit_reason'].unique():
            reason_trades = sell_trades[sell_trades['exit_reason'] == reason]
            wins = len(reason_trades[reason_trades['profit_loss_pct'] > 0])
            total = len(reason_trades)
            win_rate = wins / total * 100 if total > 0 else 0
            exit_stats[reason] = {'win_rate': win_rate, 'count': total}
        
        # Sort by count for better visualization
        sorted_reasons = sorted(exit_stats.keys(), key=lambda x: exit_stats[x]['count'], reverse=True)
        
        # Create bar chart
        fig, ax = plt.subplots(figsize=(12, 6))
        
        win_rates = [exit_stats[r]['win_rate'] for r in sorted_reasons]
        counts = [exit_stats[r]['count'] for r in sorted_reasons]
        
        # Use different colors for different exit types
        colors = []
        for reason in sorted_reasons:
            if 'STOP_LOSS' in reason:
                colors.append('red')
            elif 'TAKE_PROFIT' in reason:
                colors.append('green')
            elif 'FEATURE_EXIT' in reason:
                colors.append('blue')
            elif 'TIME_LIMIT' in reason:
                colors.append('orange')
            elif '+' in reason:
                colors.append('purple')  # Combined reasons
            else:
                colors.append('gray')
        
        bars = ax.bar(range(len(sorted_reasons)), win_rates, color=colors, alpha=0.7)
        
        # Add count labels
        for i, (rate, count) in enumerate(zip(win_rates, counts)):
            ax.text(i, rate + 2, f'{rate:.1f}%\n(n={count})', ha='center', fontsize=9)
        
        # Format x-axis labels
        formatted_reasons = [r.replace('_', ' ').title() for r in sorted_reasons]
        ax.set_xticks(range(len(sorted_reasons)))
        ax.set_xticklabels(formatted_reasons, rotation=45, ha='right')
        ax.set_title(f'Win Rate by Exit Reason - {prefix}')
        ax.set_ylabel('Win Rate (%)')
        ax.set_ylim(0, 100)
        
        # Add legend
        legend_elements = [
            plt.Rectangle((0,0),1,1, facecolor='red', alpha=0.7, label='Stop Loss'),
            plt.Rectangle((0,0),1,1, facecolor='green', alpha=0.7, label='Take Profit'),
            plt.Rectangle((0,0),1,1, facecolor='blue', alpha=0.7, label='Feature Exit'),
            plt.Rectangle((0,0),1,1, facecolor='orange', alpha=0.7, label='Time Limit'),
            plt.Rectangle((0,0),1,1, facecolor='purple', alpha=0.7, label='Combined')
        ]
        ax.legend(handles=legend_elements, loc='upper right')
        
        plt.tight_layout()
        plt.savefig(os.path.join(output_dir, f'{prefix}_exit_win_rate.png'), dpi=300)
        plt.close()
    
