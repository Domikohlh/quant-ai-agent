class WalkforwardMonteCarloTester:
    """Performs walkforward validation on Monte Carlo permuted data"""
    
    def __init__(self, config: BacktestConfig):
        self.config = config
        self.monte_carlo_tester = MonteCarloTester(config)
        self.walkforward_validator = WalkforwardValidator(config)
    
    @staticmethod
    def run_single_iteration(args):
        """Run a single Walkforward Monte Carlo iteration (for parallel processing)"""
        i, original_data, config, mc_tester, walkforward_validator = args
        
        try:
            # For this iteration, collect all window results
            iteration_windows = []
            
            # Get the data windows
            windows = walkforward_validator.split_data_windows(original_data)
            
            for window_idx, (train_data, test_data, window_info) in enumerate(windows):
                # Create a copy of the full data
                permuted_data = original_data.copy()
                
                # Permute only the test period
                seed = config.monte_carlo_seed + i * 1000 + window_idx
                permuted_data = mc_tester.create_permuted_price_series_range(
                    permuted_data,
                    window_info['test_start'],
                    window_info['test_end'],
                    seed
                )
                
                # Extract the permuted test data
                permuted_test_data = permuted_data[
                    (permuted_data['timestamp'] >= window_info['test_start']) &
                    (permuted_data['timestamp'] < window_info['test_end'])
                ]
                
                # Calibrate on original training data (unchanged)
                position_manager = PositionManager(config)
                position_manager.calibrate_sigmoid(train_data[config.feature_column].values)
                
                # Run in-sample backtest on original training data
                is_engine = BacktestEngine(config, train_data,
                                         config.feature_column, config.price_column)
                is_trades, is_portfolio = is_engine.run()
                
                # Run out-of-sample backtest on permuted test data
                oos_engine = BacktestEngine(config, permuted_test_data,
                                          config.feature_column, config.price_column)
                oos_trades, oos_portfolio = oos_engine.run()
                
                # Calculate metrics
                analyzer = PerformanceAnalyzer(config)
                is_metrics = analyzer.calculate_metrics(is_trades, is_portfolio)
                oos_metrics = analyzer.calculate_metrics(oos_trades, oos_portfolio)
                
                # Store window results
                window_result = {
                    'window_id': window_idx,
                    **window_info,
                    'is_sharpe': is_metrics.get('sharpe_ratio', 0),
                    'is_return': is_metrics.get('total_return_pct', 0),
                    'is_profit_factor': is_metrics.get('profit_factor', 0),
                    'is_max_drawdown': is_metrics.get('max_drawdown_pct', 0),
                    'oos_sharpe': oos_metrics.get('sharpe_ratio', 0),
                    'oos_return': oos_metrics.get('total_return_pct', 0),
                    'oos_profit_factor': oos_metrics.get('profit_factor', 0),
                    'oos_max_drawdown': oos_metrics.get('max_drawdown_pct', 0),
                    'oos_winrate': oos_metrics.get('win_rate', 0)
                }
                iteration_windows.append(window_result)
            
            # Analyze this iteration's results
            if iteration_windows:
                # Calculate aggregate metrics for this iteration
                df = pd.DataFrame(iteration_windows)
                return {
                    'iteration': i,
                    'avg_oos_return': df['oos_return'].mean(),
                    'avg_oos_sharpe': df['oos_sharpe'].mean(),
                    'avg_oos_profit_factor': df['oos_profit_factor'].mean(),
                    'avg_oos_max_drawdown': df['oos_max_drawdown'].mean(),
                    'avg_oos_winrate': df['oos_winrate'].mean(),
                    'positive_return_windows': len(df[df['oos_return'] > 0]),
                    'num_windows': len(df),
                    'success_rate': len(df[df['oos_return'] > 0]) / len(df) if len(df) > 0 else 0
                }
            
            return None
            
        except Exception as e:
            print(f"Warning: Error in Walkforward MC permutation {i}: {e}")
            return None
    
    def run_walkforward_monte_carlo(self, original_data: pd.DataFrame, n_iterations: int = 100) -> Dict:
        """
        Run walkforward validation with Monte Carlo permutation on OOS data only
        
        Args:
            original_data: Original merged data with price and features
            n_iterations: Number of Monte Carlo iterations
            
        Returns:
            Dictionary with original walkforward results and permutation results
        """
        print(f"Running Walkforward Monte Carlo test with {n_iterations} iterations...")
        print("Note: Only OOS data will be permuted, training data remains unchanged")
        
        # First, run walkforward on original data as baseline
        print("Running baseline walkforward on original data...")
        original_wf_results = self.walkforward_validator.run_walkforward_test(original_data)
        
        if not original_wf_results:
            print("Error: Could not run walkforward on original data")
            return None
        
        # Extract key metrics from original walkforward
        original_analysis = self.walkforward_validator._analyze_results(original_wf_results['windows'])
        
        # Store permutation results
        permutation_results = []
        successful_iterations = 0
        
        # Decide whether to use parallel processing
        if self.config.parallel_mode and n_iterations > 1:
            print(f"Using parallel processing with {self.config.num_processes or mp.cpu_count()} processes...")
            
            # Prepare arguments for parallel processing
            args_list = [(i, original_data, self.config, self.monte_carlo_tester, self.walkforward_validator) 
                         for i in range(n_iterations)]
            
            # Create pool and run iterations in parallel
            with mp.Pool(processes=self.config.num_processes) as pool:
                # Use imap to get progress updates
                results_iter = pool.imap(WalkforwardMonteCarloTester.run_single_iteration, args_list)
                
                # Collect results with progress updates
                for i, result in enumerate(results_iter):
                    if result is not None:
                        permutation_results.append(result)
                        successful_iterations += 1
                    if (i + 1) % 10 == 0:
                        print(f"Completed {i + 1}/{n_iterations} permutations...")
        else:
            # Sequential processing (original code)
            print("Using sequential processing...")
            
            # Run Monte Carlo permutations
            for i in range(n_iterations):
                if (i + 1) % 10 == 0:
                    print(f"Completed {i + 1}/{n_iterations} permutations...")
                
                try:
                    # For this iteration, collect all window results
                    iteration_windows = []
                    
                    # Get the data windows
                    windows = self.walkforward_validator.split_data_windows(original_data)
                    
                    for window_idx, (train_data, test_data, window_info) in enumerate(windows):
                        # Create a copy of the full data
                        permuted_data = original_data.copy()
                        
                        # Permute only the test period
                        seed = self.config.monte_carlo_seed + i * 1000 + window_idx
                        permuted_data = self.monte_carlo_tester.create_permuted_price_series_range(
                            permuted_data,
                            window_info['test_start'],
                            window_info['test_end'],
                            seed
                        )
                        
                        # Extract the permuted test data
                        permuted_test_data = permuted_data[
                            (permuted_data['timestamp'] >= window_info['test_start']) &
                            (permuted_data['timestamp'] < window_info['test_end'])
                        ]
                        
                        # Calibrate on original training data (unchanged)
                        position_manager = PositionManager(self.config)
                        position_manager.calibrate_sigmoid(train_data[self.config.feature_column].values)
                        
                        # Run in-sample backtest on original training data
                        is_engine = BacktestEngine(self.config, train_data,
                                                 self.config.feature_column, self.config.price_column)
                        is_trades, is_portfolio = is_engine.run()
                        
                        # Run out-of-sample backtest on permuted test data
                        oos_engine = BacktestEngine(self.config, permuted_test_data,
                                                  self.config.feature_column, self.config.price_column)
                        oos_trades, oos_portfolio = oos_engine.run()
                        
                        # Calculate metrics
                        analyzer = PerformanceAnalyzer(self.config)
                        is_metrics = analyzer.calculate_metrics(is_trades, is_portfolio)
                        oos_metrics = analyzer.calculate_metrics(oos_trades, oos_portfolio)
                        
                        # Store window results
                        window_result = {
                            'window_id': window_idx,
                            **window_info,
                            'is_sharpe': is_metrics.get('sharpe_ratio', 0),
                            'is_return': is_metrics.get('total_return_pct', 0),
                            'is_profit_factor': is_metrics.get('profit_factor', 0),
                            'is_max_drawdown': is_metrics.get('max_drawdown_pct', 0),
                            'oos_sharpe': oos_metrics.get('sharpe_ratio', 0),
                            'oos_return': oos_metrics.get('total_return_pct', 0),
                            'oos_profit_factor': oos_metrics.get('profit_factor', 0),
                            'oos_max_drawdown': oos_metrics.get('max_drawdown_pct', 0),
                            'oos_winrate': oos_metrics.get('win_rate', 0)
                        }
                        iteration_windows.append(window_result)
                    
                    # Analyze this iteration's results
                    if iteration_windows:
                        perm_analysis = self.walkforward_validator._analyze_results(iteration_windows)
                        
                        # Store key metrics
                        permutation_results.append({
                            'iteration': i,
                            'avg_oos_return': perm_analysis['avg_oos_return'],
                            'avg_oos_sharpe': perm_analysis['avg_oos_sharpe'],
                            'avg_oos_profit_factor': perm_analysis['avg_oos_profit_factor'],
                            'avg_oos_max_drawdown': perm_analysis['avg_oos_max_drawdown'],
                            'avg_oos_winrate': perm_analysis['avg_oos_winrate'],
                            'positive_return_windows': perm_analysis['positive_return_windows'],
                            'num_windows': perm_analysis['num_windows'],
                            'success_rate': perm_analysis['positive_return_windows'] / perm_analysis['num_windows'] if perm_analysis['num_windows'] > 0 else 0
                        })
                        successful_iterations += 1
                        
                except Exception as e:
                    print(f"Warning: Error in permutation {i}: {e}")
                    continue
        
        print(f"Completed {successful_iterations} successful permutations out of {n_iterations}")
        
        # Calculate p-values
        p_values = self._calculate_p_values(original_analysis, permutation_results)
        
        return {
            'original': original_analysis,
            'original_windows': original_wf_results['windows'],
            'permutations': permutation_results,
            'p_values': p_values,
            'num_iterations': successful_iterations
        }
    
    def _calculate_p_values(self, original: Dict, permutations: List[Dict]) -> Dict:
        """Calculate p-values for walkforward metrics"""
        if not permutations:
            return {}
        
        p_values = {}
        metrics = ['avg_oos_return', 'avg_oos_sharpe', 'avg_oos_profit_factor', 'avg_oos_winrate', 'success_rate']
        
        for metric in metrics:
            if metric in original:
                # Count how many permutations performed better
                better_count = sum(1 for p in permutations if p.get(metric, -999) >= original[metric])
                p_values[metric] = better_count / len(permutations)
        
        # For max drawdown, lower is better
        if 'avg_oos_max_drawdown' in original:
            better_count = sum(1 for p in permutations if p.get('avg_oos_max_drawdown', 999) <= original['avg_oos_max_drawdown'])
            p_values['avg_oos_max_drawdown'] = better_count / len(permutations)
        
        return p_values
    
