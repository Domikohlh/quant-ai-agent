    def create_permuted_price_series_range(self, data: pd.DataFrame, start_date: pd.Timestamp, 
                                          end_date: pd.Timestamp, seed: int) -> pd.DataFrame:
        """
        Create permuted price series only for a specific date range
        
        Args:
            data: Full dataframe with price data
            start_date: Start of range to permute
            end_date: End of range to permute
            seed: Random seed
            
        Returns:
            DataFrame with only the specified range permuted
        """
        # Split data into three parts
        before_range = data[data['timestamp'] < start_date].copy()
        in_range = data[(data['timestamp'] >= start_date) & (data['timestamp'] <= end_date)].copy()
        after_range = data[data['timestamp'] > end_date].copy()
        
        if in_range.empty:
            return data.copy()
        
        # Get the price at the boundary
        boundary_price = in_range[self.config.price_column].iloc[0]
        
        # Permute only the in-range portion
        permuted_range = self.create_permuted_price_series(in_range, seed)
        
        # Scale the permuted prices to start from the boundary price
        permuted_prices = permuted_range[self.config.price_column].values
        if permuted_prices[0] != 0:
            scale_factor = boundary_price / permuted_prices[0]
            permuted_range[self.config.price_column] = permuted_prices * scale_factor
        
        # Combine all parts back together
        result = pd.concat([before_range, permuted_range, after_range], ignore_index=True)
        result = result.sort_values('timestamp').reset_index(drop=True)
        
        return result


class WalkforwardValidator:
    """Performs walkforward validation testing"""
    
    def __init__(self, config: BacktestConfig):
        self.config = config

    
    def split_data_windows(self, data: pd.DataFrame) -> List[Tuple[pd.DataFrame, pd.DataFrame, Dict]]:
        """Split data into train/test windows"""
        windows = []
        
        start_date = data['timestamp'].min()
        end_date = data['timestamp'].max()
        
        current_start = start_date
        
        while True:
            # Calculate window boundaries
            if self.config.walkforward_period == 'hour':
                train_end = current_start + pd.DateOffset(hours=self.config.walkforward_train)
                test_start = train_end
                test_end = test_start + pd.DateOffset(hours=self.config.walkforward_test)
            elif self.config.walkforward_period == 'day':
                train_end = current_start + pd.DateOffset(days=self.config.walkforward_train)
                test_start = train_end
                test_end = test_start + pd.DateOffset(days=self.config.walkforward_test)
            elif self.config.walkforward_period == 'month':
                train_end = current_start + pd.DateOffset(months=self.config.walkforward_train)
                test_start = train_end
                test_end = test_start + pd.DateOffset(months=self.config.walkforward_test)
            elif self.config.walkforward_period == 'year':
                train_end = current_start + pd.DateOffset(years=self.config.walkforward_train)
                test_start = train_end
                test_end = test_start + pd.DateOffset(years=self.config.walkforward_test)

            if test_end > end_date:
                break
            
            # Split data
            train_data = data[(data['timestamp'] >= current_start) & 
                            (data['timestamp'] < train_end)]
            test_data = data[(data['timestamp'] >= test_start) & 
                           (data['timestamp'] < test_end)]
            
            if len(train_data) > 100 and len(test_data) > 20:
                window_info = {
                    'train_start': current_start,
                    'train_end': train_end,
                    'test_start': test_start,
                    'test_end': test_end,
                    'train_size': len(train_data),
                    'test_size': len(test_data)
                }
                windows.append((train_data, test_data, window_info))
            
            # Move to next window
            if self.config.walkforward_period == 'hour':
                current_start = current_start + pd.DateOffset(hours=self.config.walkforward_step)
            elif self.config.walkforward_period == 'day':
                current_start = current_start + pd.DateOffset(days=self.config.walkforward_step)
            elif self.config.walkforward_period == 'month':
                current_start = current_start + pd.DateOffset(months=self.config.walkforward_step)
            elif self.config.walkforward_period == 'year':
                current_start = current_start + pd.DateOffset(years=self.config.walkforward_step) 

        return windows
    
    def run_walkforward_test(self, data: pd.DataFrame) -> Dict:
        """Run walkforward validation"""
        print("Running walkforward validation...")
        
        # Split data into windows
        windows = self.split_data_windows(data)
        print(f"Found {len(windows)} valid windows")
        
        if not windows:
            return None
        
        results = []
        all_oos_trades = []
        all_oos_portfolio = []
        
        for i, (train_data, test_data, window_info) in enumerate(windows):
            print(f"Processing window {i+1}/{len(windows)}")
            
            try:
                # Calibrate on training data
                position_manager = PositionManager(self.config)
                position_manager.calibrate_sigmoid(train_data[self.config.feature_column].values)
                
                # Run in-sample backtest
                is_engine = BacktestEngine(self.config, train_data, 
                                         self.config.feature_column, self.config.price_column)
                is_trades, is_portfolio = is_engine.run()
                
                # Run out-of-sample backtest
                oos_engine = BacktestEngine(self.config, test_data,
                                          self.config.feature_column, self.config.price_column)
                oos_trades, oos_portfolio = oos_engine.run()
                
                # Calculate metrics
                analyzer = PerformanceAnalyzer(self.config)
                is_metrics = analyzer.calculate_metrics(is_trades, is_portfolio)
                oos_metrics = analyzer.calculate_metrics(oos_trades, oos_portfolio)
                
                # Store results
                window_result = {
                    'window_id': i,
                    **window_info,
                    'is_sharpe': is_metrics.get('sharpe_ratio', 0),
                    'is_return': is_metrics.get('total_return_pct', 0),
                    'is_profit_factor': is_metrics.get('profit_factor', 0),
                    'is_max_drawdown': is_metrics.get('max_drawdown_pct', 0),
                    'oos_sharpe': oos_metrics.get('sharpe_ratio', 0),
                    'oos_return': oos_metrics.get('total_return_pct', 0),
                    'oos_profit_factor': oos_metrics.get('profit_factor', 0),
                    'oos_max_drawdown': oos_metrics.get('max_drawdown_pct', 0),
                    'oos_winrate': oos_metrics.get('win_rate', 0)
                }
                results.append(window_result)
                
                # Collect OOS results
                if not oos_trades.empty:
                    all_oos_trades.append(oos_trades)
                if not oos_portfolio.empty:
                    all_oos_portfolio.append(oos_portfolio)
                
            except Exception as e:
                print(f"Error in window {i}: {e}")
                continue
        
        # Analyze results
        analysis = self._analyze_results(results)
        
        return {
            'windows': results,
            'analysis': analysis,
            'combined_oos_trades': pd.concat(all_oos_trades) if all_oos_trades else pd.DataFrame(),
            'combined_oos_portfolio': pd.concat(all_oos_portfolio) if all_oos_portfolio else pd.DataFrame()
        }
    
    def _analyze_results(self, results: List[Dict]) -> Dict:
        """Analyze walkforward results"""
        if not results:
            return {}
        
        df = pd.DataFrame(results)
        
        return {
            'num_windows': len(results),
            'avg_oos_sharpe': df['oos_sharpe'].mean(),
            'avg_oos_return': df['oos_return'].mean(),
            'avg_oos_profit_factor': df['oos_profit_factor'].mean(),
