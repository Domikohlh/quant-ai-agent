def load_data(file_path: str) -> pd.DataFrame:
    """Load and preprocess data"""
    print(f"Loading data from {file_path}...")
    
    df = pd.read_csv(file_path)
    
    if len(df.columns) < 2:
        raise ValueError(f"Input file must have at least 2 columns, found {df.columns}")
    
    # Standardize first column as timestamp
    df.columns = ['timestamp'] + list(df.columns[1:])
    df['timestamp'] = pd.to_datetime(df['timestamp'])
    df = df.sort_values('timestamp')
    
    # Handle missing values
    if df.isnull().sum().sum() > 0:
        print(f"Found {df.isnull().sum().sum()} missing values, filling...")
        df = df.fillna(method='ffill')
    
    print(f"Loaded {len(df)} rows")
    return df


def create_transformers(config: TransformerConfig) -> List:
    """Create all transformers based on config"""
    transformers = []
    
    # Add raw data (just copy) - if enabled
    if config.enable_raw:
        transformers.append(('raw', lambda df: df[['timestamp', df.columns[1]]].copy()))
    
    # Rate of change transformers - if enabled
    if config.enable_roc:
        for period in config.roc_periods:
            transformers.append((f'{period}h_roc', RateOfChange(period)))
    
    # Z-score transformers - if enabled
    if config.enable_zscore:
        for window in config.zscore_windows:
            transformers.append((f'zscore_{window}', ZScore(window)))
    
    # Bollinger Bands - if enabled
    if config.enable_bollinger:
        transformers.append(('bb_bandwidth', BollingerBands(config.bollinger_window, config.bollinger_std, 'bandwidth')))
        transformers.append(('bb_percent_b', BollingerBands(config.bollinger_window, config.bollinger_std, 'percent_b')))
    
    # Threshold crossings - if enabled
    if config.enable_threshold:
        transformers.append(('threshold_low', ThresholdCrossing(
            config.threshold_window, config.threshold_percentile_low, 
            config.threshold_percentile_high, 'low'
        )))
        transformers.append(('threshold_high', ThresholdCrossing(
            config.threshold_window, config.threshold_percentile_low,
            config.threshold_percentile_high, 'high'
        )))
    
    # RSI - if enabled
    if config.enable_rsi:
        for window in config.rsi_windows:
            transformers.append((f'rsi_{window}', RSI(window)))
    
    # MACD - if enabled
    if config.enable_macd:
        for fast, slow, signal in config.macd_configs:
            # Create separate transformers for each MACD component
            def create_macd_line_transformer(f, s, sig):
                def macd_line_transform(df):
                    macd = MACD(f, s, sig)
                    return macd.transform(df)['line']
                return macd_line_transform
            
            def create_macd_signal_transformer(f, s, sig):
                def macd_signal_transform(df):
                    macd = MACD(f, s, sig)
                    return macd.transform(df)['signal']
                return macd_signal_transform
            
            def create_macd_histogram_transformer(f, s, sig):
                def macd_histogram_transform(df):
                    macd = MACD(f, s, sig)
                    return macd.transform(df)['histogram']
                return macd_histogram_transform
            
            transformers.append((f'macd_line_{fast}_{slow}_{signal}', create_macd_line_transformer(fast, slow, signal)))
            transformers.append((f'macd_signal_{fast}_{slow}_{signal}', create_macd_signal_transformer(fast, slow, signal)))
            transformers.append((f'macd_histogram_{fast}_{slow}_{signal}', create_macd_histogram_transformer(fast, slow, signal)))
    
    # TRIX - if enabled
    if config.enable_trix:
        for window in config.trix_windows:
            transformers.append((f'trix_{window}', TRIX(window)))
    
    # Moving Average Oscillator - if enabled
    if config.enable_ma_oscillator:
        for fast, slow, ma_type in config.ma_osc_configs:
            transformers.append((f'ma_osc_{fast}_{slow}_{ma_type}', MovingAverageOscillator(fast, slow, ma_type)))
    
    # MACD Percentage Price Oscillator - if enabled
    if config.enable_ppo:
        for fast, slow, signal in config.ppo_configs:
            # Create separate transformers for each PPO component
            def create_ppo_line_transformer(f, s, sig):
                def ppo_line_transform(df):
                    ppo = MACDPercentagePriceOscillator(f, s, sig)
                    return ppo.transform(df)['line']
                return ppo_line_transform
            
            def create_ppo_signal_transformer(f, s, sig):
                def ppo_signal_transform(df):
                    ppo = MACDPercentagePriceOscillator(f, s, sig)
                    return ppo.transform(df)['signal']
                return ppo_signal_transform
            
            def create_ppo_histogram_transformer(f, s, sig):
                def ppo_histogram_transform(df):
                    ppo = MACDPercentagePriceOscillator(f, s, sig)
                    return ppo.transform(df)['histogram']
                return ppo_histogram_transform
            
            transformers.append((f'ppo_line_{fast}_{slow}_{signal}', create_ppo_line_transformer(fast, slow, signal)))
            transformers.append((f'ppo_signal_{fast}_{slow}_{signal}', create_ppo_signal_transformer(fast, slow, signal)))
            transformers.append((f'ppo_histogram_{fast}_{slow}_{signal}', create_ppo_histogram_transformer(fast, slow, signal)))
    
    # Mass Index - if enabled
    if config.enable_mass_index:
        for period, sum_period in config.mass_index_configs:
            transformers.append((f'mass_index_{period}_{sum_period}', MassIndex(period, sum_period)))
    
    # Detrended Price Oscillator - if enabled
    if config.enable_dpo:
        for window in config.dpo_windows:
            transformers.append((f'dpo_{window}', DetrendedPriceOscillator(window)))
    
    # Distance from EMA - if enabled
    if config.enable_distance_from_ema:
        for window in config.distance_from_ema_windows:
            transformers.append((f'dist_from_ema_{window}', DistanceFromEMA(window)))
    
    # Ichimoku Cloud - if enabled
    if config.enable_ichimoku:
        for conversion_window, base_window in config.ichimoku_configs:
            # Create separate transformers for each Ichimoku component
            def create_ichimoku_conversion_transformer(conv, base):
                def ichimoku_conversion_transform(df):
                    ichimoku = IchimokuCloud(conv, base)
                    return ichimoku.transform(df)['conversion']
                return ichimoku_conversion_transform
            
            def create_ichimoku_base_transformer(conv, base):
                def ichimoku_base_transform(df):
                    ichimoku = IchimokuCloud(conv, base)
                    return ichimoku.transform(df)['base']
                return ichimoku_base_transform
            
            transformers.append((f'ichimoku_conversion_{conversion_window}_{base_window}', create_ichimoku_conversion_transformer(conversion_window, base_window)))
            transformers.append((f'ichimoku_base_{conversion_window}_{base_window}', create_ichimoku_base_transformer(conversion_window, base_window)))
    
    return transformers


def run_transformations(df: pd.DataFrame, transformers: List) -> Dict[str, pd.DataFrame]:
    """Run all transformations on the data"""
    results = {}
    
    print(f"\nRunning {len(transformers)} transformations...")
    
    for name, transformer in transformers:
        try:
            print(f"  Applying {name}...", end='')
            
            # Handle both function and class transformers
            if callable(transformer) and not hasattr(transformer, 'transform'):
                result = transformer(df)
            else:
                result = transformer.transform(df)
            
            results[name] = result
            print(f" {len(result)} rows")
            
        except Exception as e:
            print(f" Failed: {e}")
            continue
    
    return results


def save_results(results: Dict[str, pd.DataFrame], config: TransformerConfig):
    """Save all transformation results"""
    base_filename = os.path.splitext(os.path.basename(config.input_file))[0]
    output_dir = os.path.join(config.output_dir, base_filename)
    os.makedirs(output_dir, exist_ok=True)
    
    print(f"\nSaving results to {output_dir}...")
    
    for name, df in results.items():
        clean_basename = base_filename.replace("_price", "").replace("price_", "").replace("price", "")
        clean_basename = clean_basename.replace("__", "_").strip("_")
        filename = f"{clean_basename}_{name}.csv"
        filepath = os.path.join(output_dir, filename)
        df.to_csv(filepath, index=False)
        print(f"  Saved {filename} ({len(df)} rows)")


def main():
    """Main execution"""
    # Example configuration - update these paths
    config = TransformerConfig()
    
    # Check if input file exists
    if not os.path.isfile(config.input_file):
        print(f"Error: Input file '{config.input_file}' not found")
        print("Please update the input_file path in the main() function")
        sys.exit(1)
    
    try:
        # Load data
        data = load_data(config.input_file)
        
        # Create transformers
        transformers = create_transformers(config)
        
        # Run transformations
        results = run_transformations(data, transformers)
        
        # Save results
        save_results(results, config)
        
        # Print summary
        print(f"\nTransformation Summary:")
        print(f"  Total transformations: {len(results)}")
        print(f"  Output directory: {os.path.join(config.output_dir, os.path.splitext(os.path.basename(config.input_file))[0])}")
        print("\nCompleted successfully!")
        
    except Exception as e:
        print(f"\nError: {e}")
        sys.exit(1)


if __name__ == "__main__":
    main() 
