class RateOfChange:
    """Calculate Rate of Change"""
    def __init__(self, periods: int):
        self.periods = periods
    
    def transform(self, df: pd.DataFrame) -> pd.DataFrame:
        feature_name = df.columns[1]
        result = pd.DataFrame()
        result['timestamp'] = df['timestamp']
        result[f'{feature_name}_{self.periods}h_roc'] = df[feature_name].pct_change(self.periods) * 100
        return result.dropna()
    
    def get_name(self) -> str:
        return f'{self.periods}h_roc'


class ZScore:
    """Calculate rolling Z-score"""
    def __init__(self, window: int):
        self.window = window
    
    def transform(self, df: pd.DataFrame) -> pd.DataFrame:
        feature_name = df.columns[1]
        rolling_mean = df[feature_name].rolling(window=self.window).mean()
        rolling_std = df[feature_name].rolling(window=self.window).std()
        
        result = pd.DataFrame()
        result['timestamp'] = df['timestamp']
        result[f'{feature_name}_zscore_{self.window}'] = (df[feature_name] - rolling_mean) / rolling_std
        return result.dropna()
    
    def get_name(self) -> str:
        return f'zscore_{self.window}'


class BollingerBands:
    """Calculate Bollinger Bands metrics"""
    def __init__(self, window: int = 20, num_std: int = 2, metric: str = 'bandwidth'):
        self.window = window
        self.num_std = num_std
        self.metric = metric
    
    def transform(self, df: pd.DataFrame) -> pd.DataFrame:
        feature_name = df.columns[1]
        rolling_mean = df[feature_name].rolling(window=self.window).mean()
        rolling_std = df[feature_name].rolling(window=self.window).std()
        
        upper_band = rolling_mean + (rolling_std * self.num_std)
        lower_band = rolling_mean - (rolling_std * self.num_std)
        
        result = pd.DataFrame()
        result['timestamp'] = df['timestamp']
        
        if self.metric == 'bandwidth':
            result['bb_bandwidth'] = (upper_band - lower_band) / rolling_mean
        else:  # percent_b
            result['bb_percent_b'] = (df[feature_name] - lower_band) / (upper_band - lower_band)
        
        return result.dropna()
    
    def get_name(self) -> str:
        return f'bb_{self.metric}'


class ThresholdCrossing:
    """Detect threshold crossings"""
    def __init__(self, window: int = 168, percentile_low: int = 20, 
                 percentile_high: int = 80, direction: str = 'low'):
        self.window = window
        self.percentile_low = percentile_low
        self.percentile_high = percentile_high
        self.direction = direction
    
    def transform(self, df: pd.DataFrame) -> pd.DataFrame:
        feature_name = df.columns[1]
        result = pd.DataFrame()
        result['timestamp'] = df['timestamp']
        
        if self.direction == 'low':
            threshold = df[feature_name].rolling(window=self.window).apply(
                lambda x: np.percentile(x, self.percentile_low)
            )
            result['threshold_low_cross'] = (
                (df[feature_name] <= threshold) & 
                (df[feature_name].shift(1) > threshold)
            ).astype(int)
        else:  # 'high'
            threshold = df[feature_name].rolling(window=self.window).apply(
                lambda x: np.percentile(x, self.percentile_high)
            )
            result['threshold_high_cross'] = (
                (df[feature_name] >= threshold) & 
                (df[feature_name].shift(1) < threshold)
            ).astype(int)
        
        return result.dropna()
    
    def get_name(self) -> str:
        return f'threshold_{self.direction}_cross'


class RSI:
    """Calculate Relative Strength Index"""
    def __init__(self, window: int = 14):
        self.window = window
    
    def transform(self, df: pd.DataFrame) -> pd.DataFrame:
        feature_name = df.columns[1]
        
        # Calculate price changes
        delta = df[feature_name].diff()
        gains = delta.where(delta > 0, 0)
        losses = -delta.where(delta < 0, 0)
        
        # Calculate average gains and losses
        avg_gains = gains.rolling(window=self.window).mean()
        avg_losses = losses.rolling(window=self.window).mean()
        
        # Calculate RSI
        rs = avg_gains / avg_losses
        rsi = 100 - (100 / (1 + rs))
        
        result = pd.DataFrame()
        result['timestamp'] = df['timestamp']
        result[f'{feature_name}_rsi_{self.window}'] = rsi
        return result.dropna()
    
    def get_name(self) -> str:
        return f'rsi_{self.window}'


class MACD:
    """Calculate MACD (Moving Average Convergence Divergence)"""
    def __init__(self, fast_window: int = 12, slow_window: int = 26, signal_window: int = 9):
        self.fast_window = fast_window
        self.slow_window = slow_window
        self.signal_window = signal_window
    
    def transform(self, df: pd.DataFrame) -> pd.DataFrame:
        feature_name = df.columns[1]
        
        # Calculate EMAs
        ema_fast = df[feature_name].ewm(span=self.fast_window).mean()
        ema_slow = df[feature_name].ewm(span=self.slow_window).mean()
        
        # Calculate MACD line
        macd_line = ema_fast - ema_slow
        
        # Calculate signal line
        signal_line = macd_line.ewm(span=self.signal_window).mean()
        
        # Calculate histogram
        histogram = macd_line - signal_line
        
        # Return dictionary with separate components
        results = {}
        
        # MACD Line
        line_df = pd.DataFrame()
        line_df['timestamp'] = df['timestamp']
        line_df[f'{feature_name}_macd_line_{self.fast_window}_{self.slow_window}_{self.signal_window}'] = macd_line
        results['line'] = line_df.dropna()
        
        # MACD Signal
        signal_df = pd.DataFrame()
        signal_df['timestamp'] = df['timestamp']
        signal_df[f'{feature_name}_macd_signal_{self.fast_window}_{self.slow_window}_{self.signal_window}'] = signal_line
        results['signal'] = signal_df.dropna()
        
        # MACD Histogram
        histogram_df = pd.DataFrame()
        histogram_df['timestamp'] = df['timestamp']
        histogram_df[f'{feature_name}_macd_histogram_{self.fast_window}_{self.slow_window}_{self.signal_window}'] = histogram
        results['histogram'] = histogram_df.dropna()
        
        return results
    
    def get_name(self) -> str:
        return f'macd_{self.fast_window}_{self.slow_window}_{self.signal_window}'


class TRIX:
    """Calculate TRIX (Triple Exponential Average)"""
    def __init__(self, window: int = 14):
        self.window = window
    
    def transform(self, df: pd.DataFrame) -> pd.DataFrame:
        feature_name = df.columns[1]
        
        # Calculate triple exponential smoothing
        ema1 = df[feature_name].ewm(span=self.window).mean()
        ema2 = ema1.ewm(span=self.window).mean()
        ema3 = ema2.ewm(span=self.window).mean()
        
        # Calculate TRIX as percentage change of EMA3
        trix = ema3.pct_change() * 100
        
        result = pd.DataFrame()
        result['timestamp'] = df['timestamp']
        result[f'{feature_name}_trix_{self.window}'] = trix
        return result.dropna()
    
    def get_name(self) -> str:
        return f'trix_{self.window}'


class MovingAverageOscillator:
    """Calculate Moving Average Oscillator"""
    def __init__(self, fast_window: int = 10, slow_window: int = 30, ma_type: str = 'sma'):
        self.fast_window = fast_window
        self.slow_window = slow_window
        self.ma_type = ma_type  # 'sma' or 'ema'
    
    def transform(self, df: pd.DataFrame) -> pd.DataFrame:
        feature_name = df.columns[1]
        
        if self.ma_type == 'ema':
            fast_ma = df[feature_name].ewm(span=self.fast_window).mean()
            slow_ma = df[feature_name].ewm(span=self.slow_window).mean()
        else:  # sma
            fast_ma = df[feature_name].rolling(window=self.fast_window).mean()
            slow_ma = df[feature_name].rolling(window=self.slow_window).mean()
        
        # Calculate oscillator
        oscillator = fast_ma - slow_ma
        
        result = pd.DataFrame()
        result['timestamp'] = df['timestamp']
        result[f'{feature_name}_ma_osc_{self.fast_window}_{self.slow_window}'] = oscillator
        return result.dropna()
    
    def get_name(self) -> str:
        return f'ma_osc_{self.fast_window}_{self.slow_window}_{self.ma_type}'


class MACDPercentagePriceOscillator:
    """Calculate MACD Percentage Price Oscillator (PPO)"""
    def __init__(self, fast_window: int = 12, slow_window: int = 26, signal_window: int = 9):
        self.fast_window = fast_window
        self.slow_window = slow_window
        self.signal_window = signal_window
    
    def transform(self, df: pd.DataFrame) -> pd.DataFrame:
        feature_name = df.columns[1]
        
        # Calculate EMAs
        ema_fast = df[feature_name].ewm(span=self.fast_window).mean()
        ema_slow = df[feature_name].ewm(span=self.slow_window).mean()
        
        # Calculate PPO line (as percentage)
        ppo_line = ((ema_fast - ema_slow) / ema_slow) * 100
        
        # Calculate signal line
        signal_line = ppo_line.ewm(span=self.signal_window).mean()
        
        # Calculate histogram
        histogram = ppo_line - signal_line
        
        # Return dictionary with separate components
        results = {}
        
        # PPO Line
        line_df = pd.DataFrame()
        line_df['timestamp'] = df['timestamp']
        line_df[f'{feature_name}_ppo_line_{self.fast_window}_{self.slow_window}_{self.signal_window}'] = ppo_line
        results['line'] = line_df.dropna()
        
        # PPO Signal
        signal_df = pd.DataFrame()
        signal_df['timestamp'] = df['timestamp']
        signal_df[f'{feature_name}_ppo_signal_{self.fast_window}_{self.slow_window}_{self.signal_window}'] = signal_line
        results['signal'] = signal_df.dropna()
        
        # PPO Histogram
        histogram_df = pd.DataFrame()
        histogram_df['timestamp'] = df['timestamp']
        histogram_df[f'{feature_name}_ppo_histogram_{self.fast_window}_{self.slow_window}_{self.signal_window}'] = histogram
        results['histogram'] = histogram_df.dropna()
        
        return results
    
    def get_name(self) -> str:
        return f'ppo_{self.fast_window}_{self.slow_window}_{self.signal_window}'


class MassIndex:
    """Calculate Mass Index Indicator"""
    def __init__(self, period: int = 9, sum_period: int = 25):
        self.period = period  # Period for EMA calculation
        self.sum_period = sum_period  # Period for summing the ratio
    
    def transform(self, df: pd.DataFrame) -> pd.DataFrame:
        feature_name = df.columns[1]
        
        # For single-column data, we'll use the difference between rolling max and min
        # as a proxy for high-low range
        rolling_max = df[feature_name].rolling(window=self.period).max()
        rolling_min = df[feature_name].rolling(window=self.period).min()
        high_low = rolling_max - rolling_min
        
        # Calculate EMA of high-low
        ema_hl = high_low.ewm(span=self.period).mean()
        
        # Calculate ratio and its sum
        ratio = high_low / ema_hl
        mass_index = ratio.rolling(window=self.sum_period).sum()
        
        result = pd.DataFrame()
        result['timestamp'] = df['timestamp']
        result[f'{feature_name}_mass_index_{self.period}_{self.sum_period}'] = mass_index
        return result.dropna()
    
    def get_name(self) -> str:
        return f'mass_index_{self.period}_{self.sum_period}'


class DetrendedPriceOscillator:
    """Calculate Detrended Price Oscillator (DPO)"""
    def __init__(self, window: int = 20):
        self.window = window
    
    def transform(self, df: pd.DataFrame) -> pd.DataFrame:
        feature_name = df.columns[1]
        
        # Calculate simple moving average
        sma = df[feature_name].rolling(window=self.window).mean()
        
        # Shift the SMA back by (window/2 + 1) periods to remove trend
        shift_periods = self.window // 2 + 1
        sma_shifted = sma.shift(shift_periods)
        
        # Calculate DPO: Current price - shifted SMA
        dpo = df[feature_name] - sma_shifted
        
        result = pd.DataFrame()
        result['timestamp'] = df['timestamp']
        result[f'{feature_name}_dpo_{self.window}'] = dpo
        return result.dropna()
    
    def get_name(self) -> str:
        return f'dpo_{self.window}'


class DistanceFromEMA:
    """Calculate Distance from EMA (Normalized by Price)"""
    def __init__(self, window: int = 12):
        self.window = window
    
    def transform(self, df: pd.DataFrame) -> pd.DataFrame:
        feature_name = df.columns[1]
        
        # Calculate EMA
        ema = df[feature_name].ewm(span=self.window).mean()
        
        # Calculate distance from EMA, normalized by price
        distance_from_ema = ((df[feature_name] - ema) / df[feature_name]) * 100
        
        result = pd.DataFrame()
        result['timestamp'] = df['timestamp']
        result[f'{feature_name}_dist_from_ema_{self.window}'] = distance_from_ema
        return result.dropna()
    
    def get_name(self) -> str:
        return f'dist_from_ema_{self.window}'


class IchimokuCloud:
    """Calculate Ichimoku Cloud Components (Conversion Line and Base Line)"""
    def __init__(self, conversion_window: int = 9, base_window: int = 26):
        self.conversion_window = conversion_window
        self.base_window = base_window
    
    def transform(self, df: pd.DataFrame) -> pd.DataFrame:
        feature_name = df.columns[1]
        
        # Calculate Conversion Line (Tenkan-sen): (Highest High + Lowest Low) / 2 over conversion_window
        conversion_high = df[feature_name].rolling(window=self.conversion_window).max()
        conversion_low = df[feature_name].rolling(window=self.conversion_window).min()
        conversion_line = (conversion_high + conversion_low) / 2
        
        # Calculate Base Line (Kijun-sen): (Highest High + Lowest Low) / 2 over base_window
        base_high = df[feature_name].rolling(window=self.base_window).max()
        base_low = df[feature_name].rolling(window=self.base_window).min()
        base_line = (base_high + base_low) / 2
        
        # Return dictionary with separate components
        results = {}
        
        # Conversion Line
        conversion_df = pd.DataFrame()
        conversion_df['timestamp'] = df['timestamp']
        conversion_df[f'{feature_name}_ichimoku_conversion_{self.conversion_window}_{self.base_window}'] = conversion_line
        results['conversion'] = conversion_df.dropna()
        
        # Base Line
        base_df = pd.DataFrame()
        base_df['timestamp'] = df['timestamp']
        base_df[f'{feature_name}_ichimoku_base_{self.conversion_window}_{self.base_window}'] = base_line
        results['base'] = base_df.dropna()
        
        return results
    
    def get_name(self) -> str:
        return f'ichimoku_{self.conversion_window}_{self.base_window}'


