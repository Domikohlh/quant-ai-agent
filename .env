# .env

# ==========================================
# 1. SYSTEM CONFIGURATION
# ==========================================
# Mode: "dev" (local), "active" (market hours), "monitoring" (off-hours)
APP_MODE=dev
# Logging Level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Google Cloud Project ID (from your GCP Console)
GCP_PROJECT_ID=your-gcp-project-id

# ==========================================
# 2. GOOGLE GEMINI MODELS
# ==========================================
# Get this from Google AI Studio: https://aistudio.google.com/
GOOGLE_API_KEY=your_google_api_key_here

# ==========================================
# 3. LANGSMITH OBSERVABILITY (Critical for debugging agents)
# ==========================================
# Get this from: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT="https://api.smith.langchain.com"
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT="quant_AI_agent"

# ==========================================
# 4. DATA PROVIDERS
# ==========================================
# Brave Search API (for Sentiment Analyst News)
# Get this from: https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key

# FRED API (for Economic Data like GDP, Unemployment)
# Get this from: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# ==========================================
# 5. BROKERAGE ACCOUNTS
# ==========================================

# --- Interactive Brokers (IBKR) ---
# Host: '127.0.0.1' if running locally or on the same VM
# Port: 7497 (Paper Trading TWS), 4002 (Paper Trading Gateway), 7496 (Live TWS)
IB_HOST=127.0.0.1
IB_PORT=4002
IB_ACCOUNT_ID=DU1234567

# --- Alpaca (For Paper Trading / Backtesting) ---
# Get these from: https://alpaca.markets/
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_ENDPOINT="https://paper-api.alpaca.markets"

# ==========================================
# 6. DATABASE (MCP)
# ==========================================
# Path to your SQLite database file for agent memory
SQLITE_DB_PATH=./data/agent_memory.sqlite
